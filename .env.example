# ── LLM (OpenAI 호환 chat/completions) ──────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# ── Synaptic Memory 임베딩 (OpenAI 호환 /v1 base URL) ─
# 내부에서 /embeddings를 자동으로 붙이므로 base URL까지만 지정
SYNAPTIC_EMBED_URL=https://api.openai.com/v1
SYNAPTIC_EMBED_MODEL=text-embedding-3-small

# ── 레거시 openai-proxy 경로 호환 ───────────────────
OPENAI_API_KEY=
