# ── LLM (OpenAI 호환 chat/completions) ──────────────
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# ── Synaptic Memory 임베딩 (OpenAI 호환 /v1 base URL) ─
# 내부에서 /embeddings를 자동으로 붙이므로 base URL까지만 지정
SYNAPTIC_EMBED_URL=https://api.openai.com/v1
SYNAPTIC_EMBED_MODEL=text-embedding-3-small

# ── 레거시 openai-proxy 경로 호환 ───────────────────
OPENAI_API_KEY=

# ── GitHub Members 탭 ───────────────────────────────
GITHUB_ORG=PlateerLab
# (선택) Personal Access Token (scope: public_repo, read:org)
# 없으면 시간당 60회 제한, 운영환경에선 반드시 설정 권장
GITHUB_TOKEN=
# 캐시 유효기간(초) — 기본 1800 = 30분
MEMBERS_REVALIDATE_SECONDS=1800
# /api/members/revalidate 호출용 시크릿 헤더 값 (X-Revalidate-Token)
MEMBERS_REVALIDATE_TOKEN=

# ── /demo 폼 수신 웹훅 ──────────────────────────────
# Google Apps Script 웹앱 URL (구글 시트 저장 + 이메일 발송). docs/demo-webhook.gs 참고.
DEMO_WEBHOOK_URL=

# ── /newsletter 구독 수신 웹훅 ──────────────────────
# Google Apps Script 웹앱 URL (구글 시트 upsert + 확인 메일). docs/newsletter-webhook.gs 참고.
# 미설정 시 서버 로그로만 기록됨(구독 자체는 정상 접수).
NEWSLETTER_WEBHOOK_URL=
