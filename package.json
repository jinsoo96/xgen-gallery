{
  "name": "@plateerlab/xgen-gallery",
  "version": "0.3.1",
  "description": "React component to showcase GitHub organization repositories",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsup": "^8",
    "typescript": "^5"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PlateerLab/xgen-gallery.git"
  },
  "keywords": [
    "react",
    "github",
    "gallery",
    "plateerlab",
    "xgen"
  ]
}
